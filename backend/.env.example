# MAESTRO Backend Environment Variables
# Railway will automatically set DATABASE_URL and other secrets
# For local development, copy to .env and fill in

# ─── Server ────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO

# ─── Supabase (Database + Storage) ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-supabase
SUPABASE_SERVICE_KEY=your-service-key-from-supabase

# ─── OpenRouter (GURU AI) ──────────────────────────────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Railway will override DATABASE_URL with Postgres addon
# DATABASE_URL=postgresql://...

# ─── Audio Settings ────────────────────────────────────────────────────────
# Sample rate for synthesis (DO NOT CHANGE)
SR=22050

# Maximum file size in MB
MAX_FILE_SIZE_MB=100

# Session cache size (arrangements in memory)
MAX_SESSIONS=30
