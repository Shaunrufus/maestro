# MAESTRO Environment Variables
# Copy this file to .env and fill in your actual values

# ─── Backend / Railway ─────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/maestro

# ─── OpenRouter (for GURU AI) ─────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key-here

# ─── Frontend (React Native) ───────────────────────────────────────────────
# These are baked into the app.json & StudioScreen.tsx
# BACKEND_URL will be set to Railway Production URL after deploy
